{
  "manifest_version": 2,
  "name": "Tuathau",
  "version": "0.1",
  "description": "Make Plurk avatars larger",
  "icons": null,
  "browser_specific_settings": {
    "gecko": {
      "id": "tuathau@rschiang.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["tuathau.js"],
    "service_worker": "tuathau.js"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "*://*.plurk.com/*"
  ]
}
